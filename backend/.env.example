MONGO_URL=mongodb://localhost:27017
DB_NAME=teonox_ai
CORS_ORIGINS=http://localhost:3000

GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_COMPLETION_TOKENS=4096

USAGE_HASH_SECRET=replace-with-a-long-random-secret
AI_FEATURES_ENABLED=true
AI_MAX_INPUT_CHARS=1500
AI_CONSULTANT_FREE_DAILY_LIMIT=6
AI_CONSULTANT_LEAD_DAILY_LIMIT=18
AI_JOB_RISK_FREE_DAILY_LIMIT=4
AI_JOB_RISK_LEAD_DAILY_LIMIT=12
AI_VISITOR_10MIN_LIMIT=10
AI_IP_HOURLY_LIMIT=60
AI_IP_DAILY_LIMIT=200
AI_GLOBAL_DAILY_LIMIT=1000
LEAD_MIN_FORM_SECONDS=3
